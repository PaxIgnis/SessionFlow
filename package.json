{
  "name": "session-flow",
  "description": "manifest.json description",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "vue-tsc --noEmit",
    "test": "pnpm run test:non-e2e",
    "test:coverage": "vitest run --coverage --passWithNoTests tests/unit tests/integration tests/regression tests/property",
    "coverage:merge": "node tests/scripts/merge-coverage.mjs",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:regression": "vitest run tests/regression",
    "test:property": "vitest run --passWithNoTests tests/property",
    "test:non-e2e": "pnpm run test:unit && pnpm run test:integration && pnpm run test:regression && pnpm run test:property",
    "test:all": "pnpm run test:non-e2e && pnpm run test:e2e",
    "test:coverage:all": "pnpm run test:coverage && pnpm run test:e2e:coverage && pnpm run coverage:merge",
    "test:e2e:workflows": "wdio run ./wdio.conf.mjs",
    "test:e2e:restart": "wdio run ./wdio.restart.conf.mjs",
    "test:e2e": "pnpm run zip:firefox && pnpm run test:e2e:workflows && pnpm run test:e2e:restart",
    "test:e2e:coverage": "cross-env E2E_COVERAGE=true pnpm run zip:firefox && cross-env E2E_COVERAGE=true pnpm exec wdio run ./wdio.conf.mjs && cross-env E2E_COVERAGE=true E2E_COVERAGE_APPEND=true pnpm exec wdio run ./wdio.restart.conf.mjs",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "pnpm run compile && pnpm run lint",
    "postinstall": "wxt prepare",
    "format": "prettier . --write"
  },
  "dependencies": {
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.43",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "4.1.8",
    "@wdio/cli": "^9.28.0",
    "@wdio/globals": "^9.28.0",
    "@wdio/local-runner": "^9.28.0",
    "@wdio/mocha-framework": "^9.28.0",
    "@wdio/spec-reporter": "^9.28.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "expect-webdriverio": "^5.6.8",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "prettier": "3.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite-plugin-istanbul": "^6.0.2",
    "vite-plugin-svg-sprite": "^0.7.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5",
    "webdriverio": "^9.28.0",
    "wxt": "^0.20.26"
  }
}
